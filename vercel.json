{
  "version": 2,
  "outputDirectory": "public",
  "functions": {
    "api/**/*.js": {
      "includeFiles": ["data/births.db", "node_modules/sql.js/dist/sql-wasm.wasm"]
    }
  },
  "rewrites": [
    { "source": "/data/console", "destination": "/console.html" },
    { "source": "/data/download", "destination": "/api/download" }
  ]
}
