{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    },
    {
      "src": "data/download.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/data/download(.*)", "dest": "/data/download.js$1" },
    { "src": "/data/console", "dest": "/public/console.html" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ]
}
